{
  "schema_version": 2,
  "metadata": {
    "id": "stage4-discovery-conflict",
    "description": "Conflicting discovery expires and a refreshed record reconnects production QUIC.",
    "tags": [
      "discovery",
      "regression",
      "stage4"
    ]
  },
  "requirements": {
    "controlled_runtime": true,
    "virtual_time": true,
    "synthetic_ip": true,
    "nat": false,
    "relay": false,
    "discovery": true,
    "mobility": false
  },
  "budgets": {
    "max_events": 100000,
    "max_virtual_time_nanos": 60000000000,
    "max_tasks": 1024,
    "max_packets": 10000,
    "max_trace_events": 200000,
    "max_obligations": 1024,
    "max_actions": 64,
    "max_payload_bytes": 1048576
  },
  "topology": {
    "hosts": [
      {
        "id": "client",
        "interfaces": [
          { "id": "eth0", "link": "lan", "addresses": ["192.0.2.1/24"] }
        ]
      },
      {
        "id": "server",
        "interfaces": [
          { "id": "eth0", "link": "lan", "addresses": ["192.0.2.2/24"] }
        ]
      }
    ],
    "links": [
      {
        "id": "lan",
        "latency_nanos": 1000000,
        "bits_per_second": 1000000000,
        "mtu": 1500,
        "queue_packets": 1024
      }
    ],
    "nats": [],
    "discovery": [
      { "id": "bad", "max_records": 4 },
      { "id": "good", "max_records": 4 }
    ]
  },
  "endpoints": [
    { "id": "client", "host": "client", "bind": "192.0.2.1:31001", "identity_ordinal": 1 },
    { "id": "server", "host": "server", "bind": "192.0.2.2:31002", "identity_ordinal": 2 }
  ],
  "actions": [
    {
      "id": "01-start-client",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "start_endpoint", "endpoint": "client" }
    },
    {
      "id": "02-start-server",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "start_endpoint", "endpoint": "server" }
    },
    {
      "id": "03-bad-record",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": {
        "kind": "discovery_update",
        "provider": "bad",
        "record": "bad-server",
        "endpoint": "server",
        "addresses": ["192.0.2.99:31002"],
        "delay_nanos": 1000000,
        "ttl_nanos": 20000000,
        "state": "published"
      }
    },
    {
      "id": "04-good-record",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": {
        "kind": "discovery_update",
        "provider": "good",
        "record": "good-server",
        "endpoint": "server",
        "addresses": ["192.0.2.2:31002"],
        "delay_nanos": 3000000,
        "ttl_nanos": 20000000,
        "state": "published"
      }
    },
    {
      "id": "05-connect",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "connect", "client": "client", "server": "server", "connection": "c1" }
    },
    {
      "id": "06-stream",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "stream_round_trip", "connection": "c1", "payload": { "bytes": 31, "fill": 87 } }
    },
    {
      "id": "07-close",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "close_connection", "connection": "c1" }
    },
    {
      "id": "08-expire-records",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "advance_time", "by_nanos": 30000000 }
    },
    {
      "id": "09-good-refresh",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": {
        "kind": "discovery_update",
        "provider": "good",
        "record": "good-server-refresh",
        "endpoint": "server",
        "addresses": ["192.0.2.2:31002"],
        "delay_nanos": 1000000,
        "ttl_nanos": 20000000,
        "state": "published"
      }
    },
    {
      "id": "10-reconnect",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "connect", "client": "client", "server": "server", "connection": "c2" }
    },
    {
      "id": "11-stream-reconnected",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "stream_round_trip", "connection": "c2", "payload": { "bytes": 33, "fill": 90 } }
    },
    {
      "id": "12-close-reconnected",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "close_connection", "connection": "c2" }
    },
    {
      "id": "13-stop-client",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "stop_endpoint", "endpoint": "client" }
    },
    {
      "id": "14-stop-server",
      "schedule": { "kind": "at", "nanos": 0 },
      "action": { "kind": "stop_endpoint", "endpoint": "server" }
    }
  ],
  "fault_rules": [],
  "fairness": ["fifo_progress", "reachable_network"],
  "completion": { "kind": "all_actions", "shutdown_deadline_nanos": 60000000000 },
  "allowed_terminals": ["success"],
  "invariants": [
    { "name": "authentication_identity", "deadline_nanos": null, "max_events": null },
    { "name": "delivery_integrity", "deadline_nanos": null, "max_events": null },
    { "name": "monotonic_lifecycle", "deadline_nanos": null, "max_events": null },
    { "name": "resource_cleanup", "deadline_nanos": 60000000000, "max_events": 100000 }
  ]
}
