{
  "schema_version": 2,
  "metadata": {"id": "relay/stage5-restart", "description": "Production relay restart and QUIC recovery", "tags": ["relay", "stage5"]},
  "requirements": {"controlled_runtime": true, "virtual_time": true, "synthetic_ip": true, "nat": false, "relay": true, "discovery": false, "mobility": false},
  "budgets": {"max_events": 100000, "max_virtual_time_nanos": 60000000000, "max_tasks": 1024, "max_packets": 10000, "max_trace_events": 200000, "max_obligations": 1024, "max_actions": 64, "max_payload_bytes": 1048576},
  "topology": {
    "hosts": [
      {"id": "client", "interfaces": [{"id": "eth0", "link": "lan", "addresses": ["192.0.2.1/24"]}]},
      {"id": "server", "interfaces": [{"id": "eth0", "link": "lan", "addresses": ["192.0.2.2/24"]}]}
    ],
    "links": [{"id": "lan", "latency_nanos": 1000000, "bits_per_second": 1000000000, "mtu": 1500, "queue_packets": 1024}],
    "relays": [{"id": "home", "url": "https://restart.invalid", "online": true, "max_sessions": 8, "byte_capacity": 262144, "protocol_version": "v2"}]
  },
  "endpoints": [
    {"id": "client", "host": "client", "bind": "192.0.2.1:31001", "identity_ordinal": 1, "direct": false, "relay": "home"},
    {"id": "server", "host": "server", "bind": "192.0.2.2:31002", "identity_ordinal": 2, "direct": false, "relay": "home"}
  ],
  "actions": [
    {"id": "01-start-client", "schedule": {"kind": "at", "nanos": 0}, "action": {"kind": "start_endpoint", "endpoint": "client"}},
    {"id": "02-start-server", "schedule": {"kind": "at", "nanos": 0}, "action": {"kind": "start_endpoint", "endpoint": "server"}},
    {"id": "03-connect", "schedule": {"kind": "at", "nanos": 0}, "action": {"kind": "connect", "client": "client", "server": "server", "connection": "c1"}},
    {"id": "04-stream", "schedule": {"kind": "at", "nanos": 0}, "action": {"kind": "stream_round_trip", "connection": "c1", "payload": {"bytes": 28, "fill": 165}}},
    {"id": "05-relay-offline", "schedule": {"kind": "after_action", "action": "04-stream"}, "action": {"kind": "relay_lifecycle", "relay": "home", "online": false}},
    {"id": "06-relay-online", "schedule": {"kind": "after_action", "action": "05-relay-offline"}, "action": {"kind": "relay_lifecycle", "relay": "home", "online": true}},
    {"id": "07-reconnect-window", "schedule": {"kind": "after_action", "action": "06-relay-online"}, "action": {"kind": "advance_time", "by_nanos": 2000000000}},
    {"id": "08-connect-recovered", "schedule": {"kind": "after_action", "action": "07-reconnect-window"}, "action": {"kind": "connect", "client": "client", "server": "server", "connection": "c2"}},
    {"id": "09-stream-recovered", "schedule": {"kind": "after_action", "action": "08-connect-recovered"}, "action": {"kind": "stream_round_trip", "connection": "c2", "payload": {"bytes": 37, "fill": 90}}},
    {"id": "10-close-recovered", "schedule": {"kind": "at", "nanos": 0}, "action": {"kind": "close_connection", "connection": "c2"}},
    {"id": "11-stop-client", "schedule": {"kind": "at", "nanos": 0}, "action": {"kind": "stop_endpoint", "endpoint": "client"}},
    {"id": "12-stop-server", "schedule": {"kind": "at", "nanos": 0}, "action": {"kind": "stop_endpoint", "endpoint": "server"}}
  ],
  "fault_rules": [],
  "fairness": ["fifo_progress", "reachable_network"],
  "completion": {"kind": "all_actions", "shutdown_deadline_nanos": 60000000000},
  "allowed_terminals": ["success"],
  "invariants": [
    {"name": "authentication_identity", "deadline_nanos": null, "max_events": null},
    {"name": "delivery_integrity", "deadline_nanos": null, "max_events": null},
    {"name": "monotonic_lifecycle", "deadline_nanos": null, "max_events": null},
    {"name": "reachable_connect_liveness", "deadline_nanos": 10000000000, "max_events": 50000},
    {"name": "relay_routing", "deadline_nanos": null, "max_events": null},
    {"name": "resource_cleanup", "deadline_nanos": 60000000000, "max_events": 100000}
  ]
}
